---
// Coze Agent Chat Component - Modal Version
// 使用 Coze WebSDK 实现点击按钮打开聊天窗口

interface Props {
  projectId?: string;
  className?: string;
}

const {
  projectId = import.meta.env.PUBLIC_COZE_PROJECT_ID || '',
  className = ''
} = Astro.props;
---

<div id="coze-chat-widget" class={className}>
  <!-- 聊天触发按钮 -->
  <button 
    id="coze-chat-toggle"
    class="coze-chat-button"
    aria-label="打开 AI 助手"
    title="点击与 AI 助手交互"
  >
    <!-- 动态粒子与能量核心风按钮 -->
    <div class="particle-sphere"></div>
    <div class="particle-ring"></div>
    <div class="inner-core">
      <svg class="chat-icon-beam" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
      </svg>
    </div>
    <span class="pulse-energy"></span>
  </button>

  <!-- 聊天窗口容器 (简约毛玻璃方式) -->
  <div id="coze-chat-container" class="coze-chat-modal hidden">
    <div class="coze-chat-header">
      <h2 class="glass-title">AI 助手</h2>
      <button 
        id="coze-chat-close"
        class="close-button"
        aria-label="关闭聊天"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="close-icon">
          <path d="M18 6L6 18M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    
    <!-- iframe 会由 JS 动态创建 -->
    <div id="coze-embed-container" class="coze-chat-body"></div>
  </div>

  <!-- 背景遮罩 -->
  <div id="coze-chat-backdrop" class="coze-chat-backdrop hidden"></div>
</div>

<style>
  #coze-chat-widget {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 40;
  }

  /* 聊天按钮：动态粒子与能量核心风 */
  .coze-chat-button {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    pointer-events: auto;
    z-index: 41;
    perspective: 500px;
  }

  /* 粒子球体 */
  .particle-sphere {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, rgba(64, 156, 255, 0.8), rgba(138, 43, 226, 0.9));
    box-shadow: 0 0 20px rgba(64, 156, 255, 0.6), inset 0 0 15px rgba(255, 255, 255, 0.4);
    animation: sphere-spin 8s linear infinite;
    z-index: 1;
  }

  /* 类似土星环的粒子环 */
  .particle-ring {
    position: absolute;
    width: 140%;
    height: 140%;
    border-radius: 50%;
    border: 2px dashed rgba(0, 255, 255, 0.5);
    box-shadow: 0 0 10px rgba(0, 255, 255, 0.3), inset 0 0 10px rgba(138, 43, 226, 0.3);
    animation: ring-spin 4s linear infinite;
    transform: rotateX(60deg) rotateY(20deg);
    z-index: 2;
  }

  /* 内部核心光束 */
  .inner-core {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .chat-icon-beam {
    width: 32px;
    height: 32px;
    color: #fff;
    filter: drop-shadow(0 0 8px rgba(255, 255, 255, 0.9));
    pointer-events: none;
    animation: float-pulse 2s ease-in-out infinite;
  }

  @keyframes sphere-spin {
    0% { transform: rotate(0deg) scale(1); filter: hue-rotate(0deg); }
    50% { transform: rotate(180deg) scale(0.95); filter: hue-rotate(45deg); }
    100% { transform: rotate(360deg) scale(1); filter: hue-rotate(0deg); }
  }

  @keyframes ring-spin {
    0% { transform: rotateX(60deg) rotateY(20deg) rotateZ(0deg); }
    100% { transform: rotateX(60deg) rotateY(20deg) rotateZ(360deg); }
  }

  @keyframes float-pulse {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-2px) scale(1.05); }
  }

  /* 点击爆发感交互 */
  .coze-chat-button.bursting .particle-sphere {
    animation: sphere-burst 0.5s cubic-bezier(0.19, 1, 0.22, 1) forwards;
  }

  @keyframes sphere-burst {
    0% { transform: scale(1); opacity: 1; }
    40% { transform: scale(0.5); opacity: 1; }
    100% { transform: scale(3); opacity: 0; }
  }

  /* 当 BackToTop 按钮存在时，调整 AI 按钮位置以避免重叠 */
  :global(body:has([role="button"]:is([aria-label*="Back"]), [class*="back-to-top"], [class*="scroll-to-top"])) .coze-chat-button {
    bottom: 24px;
    right: 96px;
  }

  /* 备选方案：通过兄弟选择器检测 BackToTop 的存在 */
  #coze-chat-widget:has(~ [class*="back-to-top"]) .coze-chat-button,
  [class*="back-to-top"]:not(:hidden) ~ #coze-chat-widget .coze-chat-button {
    right: 96px;
  }

  .coze-chat-button:hover {
    transform: translateY(-5px) scale(1.05);
  }
  
  .coze-chat-button:hover .particle-sphere {
    box-shadow: 0 0 30px rgba(64, 156, 255, 0.9), inset 0 0 20px rgba(255, 255, 255, 0.6);
  }

  .coze-chat-button:active {
    transform: scale(0.9);
  }

  /* 呼吸能量波 */
  .pulse-energy {
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 2px solid rgba(0, 255, 255, 0.8);
    animation: energy-pulse 2s cubic-bezier(0.25, 0.8, 0.25, 1) infinite;
    z-index: 0;
  }

  @keyframes energy-pulse {
    0% { transform: scale(1); opacity: 0.8; }
    100% { transform: scale(1.8); opacity: 0; border-color: rgba(138, 43, 226, 0); }
  }

  /* 聊天窗口背景遮罩 */
  .coze-chat-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(4px);
    z-index: 39;
    pointer-events: auto;
    transition: opacity 0.3s ease;
  }

  .coze-chat-backdrop.hidden {
    display: none;
    opacity: 0;
  }

  /* 极简聊天模态框（高质感毛玻璃） */
  .coze-chat-modal {
    position: fixed;
    bottom: 100px;
    right: 24px;
    width: 90vw;
    max-width: 400px;
    height: 600px;
    max-height: 80vh;
    border-radius: 16px;
    background: rgba(15, 23, 42, 0.75);
    backdrop-filter: blur(16px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.2);
    display: flex;
    flex-direction: column;
    z-index: 40;
    pointer-events: auto;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
    overflow: hidden;
  }
  
  /* 发消息时的微交互 */
  .coze-chat-modal.breathing {
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.3), inset 0 0 20px rgba(255, 255, 255, 0.05);
  }

  .coze-chat-modal.hidden {
    display: none;
    pointer-events: none;
    opacity: 0;
    transform: translateY(20px) scale(0.98);
  }

  .coze-chat-modal.show {
    animation: popIn 0.4s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  }

  @keyframes popIn {
    0% { opacity: 0; transform: translateY(20px) scale(0.98); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* 聊天窗口头部 */
  .coze-chat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    background: transparent;
    z-index: 10;
  }

  /* 简约标题文本 */
  .glass-title {
    margin: 0;
    font-size: 16px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.9);
    letter-spacing: 0.5px;
  }

  /* 简约关闭按钮 */
  .close-button {
    width: 32px;
    height: 32px;
    border: none;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    color: rgba(255, 255, 255, 0.7);
  }

  .close-button:hover {
    background: rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 1);
    transform: rotate(90deg);
  }

  .close-icon {
    width: 18px;
    height: 18px;
  }

  /* 聊天内容区 */
  .coze-chat-body {
    flex: 1;
    overflow: hidden;
    padding: 0;
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 1;
  }

  /* iframe 本身使其透明以露出底层效果 */
  #coze-embed-container {
    width: 100%;
    height: 100%;
  }

  #coze-embed-container iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
    background: transparent;
    color-scheme: dark;
  }

  /* 移动设备适配 */
  @media (max-width: 640px) {
    .coze-chat-button {
      bottom: 16px;
      right: 16px;
      width: 52px;
      height: 52px;
    }

    /* 移动端有 BackToTop 时的位置调整 */
    :global(body:has([role="button"]:is([aria-label*="Back"]), [class*="back-to-top"], [class*="scroll-to-top"])) .coze-chat-button {
      right: 72px;
    }

    .ai-core-container {
      width: 80px;
      height: 80px;
    }

    .ai-core {
      width: 30px;
      height: 30px;
    }
  }

  /* 深色模式支持 (本身已经是深色粒子风格，不需要强制调整) */
  :global(.dark) .coze-chat-backdrop {
    background: rgba(0, 0, 0, 0.8);
  }
</style>

<script define:vars={{ projectId }}>
  class CozeChatWidget {
    constructor() {
      this.projectId = projectId || '';
      this.container = document.getElementById('coze-embed-container');
      this.modal = document.getElementById('coze-chat-container');
      this.backdrop = document.getElementById('coze-chat-backdrop');
      this.toggleBtn = document.getElementById('coze-chat-toggle');
      this.closeBtn = document.getElementById('coze-chat-close');
      this.iframe = null;
      this.isOpen = false;
      this.iframeReady = false;
      
      // 绑定方法以便能够移除监听器
      this.handleToggle = () => this.toggle();
      this.handleClose = () => this.close();
      this.handleBackdropClick = () => this.close();
      this.handleMessageEvent = (event) => this._handleMessage(event);
      
      this.init();
    }

    init() {
      this.toggleBtn?.addEventListener('click', this.handleToggle);
      this.closeBtn?.addEventListener('click', this.handleClose);
      this.backdrop?.addEventListener('click', this.handleBackdropClick);

      // 首次打开时创建 iframe
      const createIframeOnce = () => {
        if (!this.iframe) {
          this.createIframe();
        }
        // 移除一次性监听器
        this.toggleBtn?.removeEventListener('click', createIframeOnce);
      };
      this.toggleBtn?.addEventListener('click', createIframeOnce, { once: true });
    }

    /**
     * 清理资源（导航前调用）
     */
    cleanup() {
      // 移除所有事件监听器
      this.toggleBtn?.removeEventListener('click', this.handleToggle);
      this.closeBtn?.removeEventListener('click', this.handleClose);
      this.backdrop?.removeEventListener('click', this.handleBackdropClick);
      window.removeEventListener('message', this.handleMessageEvent);
      
      // 关闭模态框
      this.close();
    }

    /**
     * 销毁实例（重新初始化前调用）
     */
    destroy() {
      this.cleanup();
      
      // 清除 iframe
      if (this.iframe) {
        this.iframe.remove();
        this.iframe = null;
      }
      
      // 清除容器内容
      if (this.container) {
        this.container.innerHTML = '';
      }
      
      this.iframeReady = false;
      this.isOpen = false;
    }

    /**
     * 创建并初始化 iframe
     */
    createIframe() {
      if (this.iframe) return;

      if (!this.projectId) {
        this.showError('缺少 Coze Project ID 配置');
        return;
      }

      try {
        // 创建 iframe 元素
        this.iframe = document.createElement('iframe');
        this.iframe.src = 'https://sdk.coze.site';
        this.iframe.style.width = '100%';
        this.iframe.style.height = '100%';
        this.iframe.style.border = 'none';
        this.iframe.style.display = 'block';

        // 监听来自 iframe 的消息
        window.addEventListener('message', this.handleMessageEvent);

        // 添加到容器
        this.container?.appendChild(this.iframe);

        // 等待 iframe 准备就绪
        setTimeout(() => {
          if (!this.iframeReady) {
            this.showError('iframe 加载超时，请检查网络连接');
          }
        }, 5000);
      } catch (error) {
        console.error('Failed to create iframe:', error);
        this.showError('AI 助手初始化出错');
      }
    }

    /**
     * 处理来自 iframe 的消息
     */
    _handleMessage(event) {
      // 只处理来自 Coze SDK 的消息
      if (event.origin !== 'https://sdk.coze.site') {
        return;
      }

      const data = event.data;
      
      if (data.type === 'IFRAME_READY') {
        this.iframeReady = true;
        this.initializeIframe();
      } else if (data.type === 'TOKEN_EXPIRED') {
        // Token 过期，需要刷新
        this.refreshTokenAndNotify();
      } else if (data.type === 'TOKEN_INVALID') {
        this.showError('Token 校验失败，请检查配置');
      } else if (data.type === 'NETWORK_ERROR') {
        this.showError('网络错误，请检查连接');
      }
    }

    /**
     * 初始化 iframe（发送初始化命令）
     */
    async initializeIframe() {
      try {
        // 获取 token
        const token = await this.getToken();
        
        if (!token) {
          this.showError('无法获取访问令牌');
          return;
        }

        // 发送初始化命令
        this.iframe?.contentWindow?.postMessage({
          type: 'INIT',
          payload: {
            projectId: this.projectId,
            token: token
          }
        }, 'https://sdk.coze.site');
      } catch (error) {
        console.error('Failed to initialize iframe:', error);
        this.showError('AI 助手初始化出错');
      }
    }

    /**
     * 获取 token
     */
    async getToken() {
      try {
        const response = await fetch('/api/coze/token', {
          credentials: 'same-origin'
        });

        if (!response.ok) {
          throw new Error('Failed to fetch token');
        }

        const data = await response.json();
        return data.token;
      } catch (error) {
        console.error('Failed to get token:', error);
        return null;
      }
    }

    /**
     * 刷新 token 并通知 iframe
     */
    async refreshTokenAndNotify() {
      const token = await this.getToken();
      if (token) {
        this.iframe?.contentWindow?.postMessage({
          type: 'UPDATE_TOKEN',
          payload: { token }
        }, 'https://sdk.coze.site');
      }
    }

    /**
     * 打开聊天窗口
     */
    open() {
      if (this.isOpen) return;
      
      // 触发爆发动画
      this.toggleBtn?.classList.add('bursting');
      
      setTimeout(() => {
        this.toggleBtn?.classList.remove('bursting');
        this.isOpen = true;
        this.modal?.classList.remove('hidden');
        this.modal?.classList.add('show');
        this.backdrop?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }, 300); // 配合 CSS 动画时长
    }

    /**
     * 关闭聊天窗口
     */
    close() {
      if (!this.isOpen) return;
      
      this.isOpen = false;
      this.modal?.classList.remove('show'); // 移除显示动画以防冲突
      this.modal?.classList.add('hidden');
      this.backdrop?.classList.add('hidden');
      document.body.style.overflow = '';
    }

    /**
     * 切换聊天窗口
     */
    toggle() {
      this.isOpen ? this.close() : this.open();
    }

    /**
     * 显示错误信息
     */
    showError(message) {
      if (!this.container) return;
      this.container.innerHTML = `
        <div style="
          display: flex;
          align-items: center;
          justify-content: center;
          height: 100%;
          text-align: center;
          padding: 20px;
          color: rgba(255, 255, 255, 0.8);
          font-size: 14px;
        ">
          <div>
            <p style="margin: 0; color: #ff3366; text-shadow: 0 0 10px rgba(255, 51, 102, 0.5);">⚠️ ${message}</p>
          </div>
        </div>
      `;
    }
  }

  // 接收 Coze Web SDK 传来的自定义消息，以触发“输入中”或“发消息”的UI交互
  window.addEventListener('message', (e) => {
    // 根据具体实现调整（这里尝试捕获iframe内输入或发送的可能事件，如果没有也不影响主要视觉体验）
    const modal = document.getElementById('coze-chat-container');
    if (!modal) return;
    
    // 假设传递了 { type: 'chat_typing' } 或者 { type: 'chat_sent' }
    if (e.data && e.data.type === 'chat_typing') {
      modal.classList.add('typing');
      clearTimeout(window._typingTimeout);
      window._typingTimeout = setTimeout(() => {
        modal.classList.remove('typing');
      }, 1500);
    } else if (e.data && e.data.type === 'chat_sent') {
      modal.classList.add('breathing');
      setTimeout(() => {
        modal.classList.remove('breathing');
      }, 1000);
    }
  });

  // 全局实例引用
  let chatWidget = null;

  /**
   * 初始化聊天小部件
   */
  function initializeChatWidget() {
    // 清理旧实例（防止重复初始化）
    if (chatWidget) {
      chatWidget.destroy?.();
    }
    chatWidget = new CozeChatWidget();
  }

  // 初始页面加载
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeChatWidget);
  } else {
    initializeChatWidget();
  }

  // 支持 Astro View Transitions（处理 SPA 导航）
  document.addEventListener('astro:after-swap', () => {
    // 重新初始化聊天小部件以获取新的 DOM 元素
    initializeChatWidget();
  });

  // 导航前清理（可选但推荐）
  document.addEventListener('astro:before-swap', () => {
    if (chatWidget?.cleanup) {
      chatWidget.cleanup();
    }
  });
</script>
